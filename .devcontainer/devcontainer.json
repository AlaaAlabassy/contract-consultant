{
  "name": "contract-consultant",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [3000, 8000, 5432, 8001, 6379],
  "portsAttributes": {
    "3000": { "label": "frontend", "onAutoForward": "openPreview" },
    "8000": { "label": "backend-api", "visibility": "private" },
    "5432": { "label": "postgres", "visibility": "private" },
    "8001": { "label": "chromadb", "visibility": "private" },
    "6379": { "label": "redis", "visibility": "private" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
