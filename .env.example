# --- Google Drive (backend ingestion via service account - no browser/OAuth needed) ---
# Path to the service account JSON key, kept OUT of git (see backend/secrets/).
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_ARCHIVING_MATRIX_FILE_ID=

# --- Google OAuth (only needed later if an interactive frontend login is added) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings (local, free, multilingual - no API key needed) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Storage (internal docker-network hostnames/ports) ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/contracts
CHROMA_HOST=chromadb
CHROMA_PORT=8000
REDIS_URL=redis://redis:6379/0

# --- Citation-lock confidence thresholds ---
CONFIDENCE_HIGH=0.90
CONFIDENCE_WARN=0.70
CONFIDENCE_REFUSE=0.50
